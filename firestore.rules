rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      // Use exists() to avoid reading a non-existent document
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }
    
    function isSuperAdmin() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'superadmin';
    }
    
    function isHospitalAdmin() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'admin';
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
    }

    // Hospitals Collection
    match /hospitals/{hospitalId} {
      allow read: if true; // Publicly searchable
      allow write: if false; // Handled by FastAPI (Super Admin/Hospital Admin)
      
      // Inventory Sub-collection
      match /inventory/{type} {
        allow read: if true;
        allow write: if false; // Handled by FastAPI
      }
    }

    // Blood Requests Collection
    match /blood_requests/{requestId} {
      allow read: if isAuthenticated();
      allow write: if false; // Handled by FastAPI
    }

    // Notifications Collection
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if false; // Handled by FastAPI
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if false;
    }
  }
}
